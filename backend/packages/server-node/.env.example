ATTACHMENT_MAX_BYTES=52428800
ATTACHMENT_TTL_DAYS=365
ATTACHMENT_STORAGE_DIR=./data/attachments
STORAGE_PROVIDER=local
# With IAM role auth on EC2, keep S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY empty.
NODE_S3_BUCKET=opencom-node
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=0
S3_KEY_PREFIX=
PUBLIC_BASE_URL=http://localhost:3002
NODE_SERVER_ID=my-node-1

# Dedicated media service used by clients for direct voice signaling.
MEDIA_SERVER_URL=http://localhost:3003
MEDIA_WS_URL=ws://localhost:3003/gateway
MEDIA_TOKEN_SECRET=replace_me_media_token_secret
MEDIA_TOKEN_ISSUER=opencom-media
MEDIA_TOKEN_AUDIENCE=
MEDIA_TOKEN_TTL_SECONDS=300
# Must match MEDIA_SYNC_SECRET on the media service.
MEDIA_SYNC_SECRET=replace_me_shared_node_sync_secret

# Legacy node-local mediasoup config is still supported for fallback/test environments.
# In the split EC2 deployment, set these on the media service instead.
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_ADDRESS=
# MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_ENABLE_UDP=1
MEDIASOUP_ENABLE_TCP=1
MEDIASOUP_PREFER_UDP=1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100

LOG_LEVEL=warn
LOG_DIR=./logs
LOG_TO_FILE=1
