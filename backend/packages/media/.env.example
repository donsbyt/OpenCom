NODE_ENV=production
MEDIA_PORT=3003
MEDIA_HOST=0.0.0.0
MEDIA_DATABASE_URL=mysql://db_user:db_password@127.0.0.1:3306/ods_node
CORE_BASE_URL=http://localhost:3000
# Public-facing URLs for clients. MEDIA_WS_URL is what the app should hand back
# to browsers/mobile clients. MEDIA_SERVER_URL is used for health/debug links and
# to infer the mediasoup announced hostname when needed.
MEDIA_SERVER_URL=https://media.example.com
MEDIA_WS_URL=wss://media.example.com/gateway
MEDIA_ALLOWED_ORIGINS=https://opencom.online,http://localhost:5173
MEDIA_TOKEN_SECRET=replace_me_with_a_long_random_secret
MEDIA_TOKEN_ISSUER=opencom-media
# Optional audience hardening if you want the media service to verify aud.
MEDIA_TOKEN_AUDIENCE=
# Internal sync secret used by the app/node service to force disconnects or room closes.
# Reuse your existing NODE_SYNC_SECRET value unless you want a dedicated one.
MEDIA_SYNC_SECRET=replace_me_shared_node_sync_secret

MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_ADDRESS=
# MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_ENABLE_UDP=1
MEDIASOUP_ENABLE_TCP=1
MEDIASOUP_PREFER_UDP=1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100

LOG_LEVEL=warn
LOG_DIR=./logs
LOG_TO_FILE=1
DEBUG_HTTP=0
DEBUG_VOICE=0
