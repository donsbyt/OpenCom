# InternalStatsAPI runtime
INTERNAL_STATS_PORT=3099
INTERNAL_STATS_HOST=127.0.0.1
INTERNAL_STATS_LOG_LEVEL=info
INTERNAL_STATS_REQUIRE_AUTH=true
INTERNAL_STATS_SYNC_SECRET=replace-with-long-shared-secret
INTERNAL_STATS_SYNC_SECRET_HEADER=x-internal-stats-secret
INTERNAL_STATS_API_TOKEN_HEADER=x-api-token

# Optional bootstrap secret for issuing/registering API tokens via endpoint
INTERNAL_STATS_GEN_SECRET=replace-with-second-long-secret
INTERNAL_STATS_GEN_SECRET_HEADER=x-internal-stats-gen-secret

INTERNAL_STATS_DEFAULT_REPORT_SOURCE=core-api
INTERNAL_STATS_RETENTION_DAYS=365
INTERNAL_STATS_RETENTION_SWEEP_MINUTES=60

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=opencom
DB_PASSWORD=replace-me
DB_NAME=opencom
