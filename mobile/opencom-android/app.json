{
  "expo": {
    "name": "OpenCom",
    "slug": "opencom-android",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "opencom",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "online.opencom.mobile",
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "opencom.online",
              "pathPrefix": "/join/"
            },
            {
              "scheme": "https",
              "host": "www.opencom.online",
              "pathPrefix": "/join/"
            }
          ]
        }
      ]
    },
    "extra": {
      "opencomCoreApiUrl": "https://api.opencom.online"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "online.opencom.mobile"
    }
  }
}
